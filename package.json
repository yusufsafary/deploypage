{
  "name": "deploypage",
  "version": "1.0.0",
  "description": "DeployPage — Turn Any Contract Into a Landing Page. Smart contracts + Vercel-ready landing page.",
  "scripts": {
    "compile":     "npx hardhat compile",
    "test":        "npx hardhat test",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network base-sepolia",
    "interact":    "npx hardhat run scripts/interact.js --network base-sepolia",
    "verify":      "npx hardhat verify --network base-sepolia",
    "dev":         "npx vercel dev",
    "build":       "echo 'Static site — no build step required'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
