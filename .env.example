# ── Base Sepolia Testnet ─────────────────────────────────────────────────────
# RPC endpoint for Base Sepolia
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Your deployer wallet private key (NEVER commit the real value!)
# Get Base Sepolia ETH from: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Basescan API key for contract verification (optional)
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
# Deployed contract address (filled after running deploy:testnet)
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_CHAIN_NAME=base-sepolia
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org
